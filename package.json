{
  "name": "portfolio-root",
  "version": "1.0.0",
  "description": "Root workspace for Portfolio Full-stack App",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev": "concurrently -k -p \"[{name}]\" -n \"Backend,Frontend\" -c \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build --prefix frontend"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
